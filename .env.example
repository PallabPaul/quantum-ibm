# =====================================================================
# IBM Quantum Platform credentials
# Copy this file to ".env" and fill in your own values.
#   cp .env.example .env
#
# Get your API key from: https://quantum.ibm.com/
# NEVER commit the real .env file — it is ignored by .gitignore.
# =====================================================================

# Your IBM Quantum API key (token).
IBM_QUANTUM_TOKEN=paste_your_new_api_key_here

# Channel for the current IBM Quantum Platform.
# Use "ibm_quantum_platform" for the current (2025+) platform.
IBM_QUANTUM_CHANNEL=ibm_quantum_platform

# Optional: instance CRN. Only needed if your account has multiple
# instances and you want to target a specific one.
# IBM_QUANTUM_INSTANCE=crn:v1:bluemix:public:quantum-computing:...
